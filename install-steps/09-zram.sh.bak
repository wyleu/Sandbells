#!/bin/bash
QUICK_MODE=${1:-false}

pause() {
    if [ "$QUICK_MODE" = true ]; then
        sleep 1.5
        return
    fi
    echo ""
    read -p "Press Enter to continue (or Q to stop) > " choice
    if [[ "$choice" =~ ^[Qq]$ ]]; then
        echo "Setup stopped safely."
        exit 1
    fi
}

echo "=================================================="
echo "ZRAM Swap Configuration (Proper zram-tools method)"
echo "=================================================="

# Install if not present
sudo apt update
sudo apt install -y zram-tools

# Calculate reasonable size
TOTAL_RAM=$(free -m | awk '/^Mem:/{print $2}')
ZRAM_SIZE=$((TOTAL_RAM / 2))
if [ $ZRAM_SIZE -gt 384 ]; then
    ZRAM_SIZE=384
fi

echo "Total RAM: ${TOTAL_RAM}M → Setting ZRAM to ${ZRAM_SIZE}M"

# Configure zram-tools the correct way
sudo bash -c "cat > /etc/default/zramswap << EOF
ALGO=lz4
SIZE=${ZRAM_SIZE}M
EOF"

# Restart the service
sudo systemctl restart zramswap.service
sudo systemctl enable zramswap.service

echo "Waiting for activation..."
sleep 3

echo "ZRAM Status:"
systemctl status zramswap.service --no-pager -l

echo ""
echo "Swap devices:"
swapon --show

echo ""
echo "ZRAM device:"
zramctl 2>/dev/null || echo "zramctl not available"

echo "ZRAM configuration completed."
pause
