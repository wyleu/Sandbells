#!/bin/bash
QUICK_MODE=${1:-false}

pause() {
    if [ "$QUICK_MODE" = true ]; then
        sleep 1.5
        return
    fi
    echo ""
    read -p "Press Enter to continue (or Q to stop) > " choice
    if [[ "$choice" =~ ^[Qq]$ ]]; then
        echo "Setup stopped safely."
        exit 1
    fi
}

echo "=================================================="
echo "Sandbells Hostname Setup - Network Scan"
echo "=================================================="

BASE_NAME="sandbells"

echo "Scanning local network for existing Sandbells instances..."

num=1
while true; do
    if [ $num -eq 1 ]; then
        candidate="$BASE_NAME"
    else
        candidate="${BASE_NAME}${num}"
    fi

    # Multiple detection methods
    taken=false
    
    if ping -c 1 -W 2 "$candidate.local" >/dev/null 2>&1; then
        taken=true
    elif ping -c 1 -W 2 "$candidate" >/dev/null 2>&1; then
        taken=true
    elif arp -a | grep -qi "$candidate" 2>/dev/null; then
        taken=true
    fi

    if [ "$taken" = false ]; then
        echo "Found available hostname: $candidate"
        break
    else
        echo "  $candidate is in use."
    fi

    num=$((num + 1))
    if [ $num -gt 30 ]; then
        echo "Too many units - using sandbells99"
        candidate="sandbells99"
        break
    fi
done

# Apply the hostname
echo "Setting hostname to: $candidate"
echo "$candidate" | sudo tee /etc/hostname > /dev/null
sudo sed -i "s/127.0.1.1.*/127.0.1.1\t$candidate/" /etc/hosts
sudo hostnamectl set-hostname "$candidate"

echo "Hostname successfully set to $candidate"
echo "=================================================="
pause
